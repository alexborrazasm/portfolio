---
import LinkGroup from './LinkGroup.astro';
import DateBadge from './DateBadge.astro';

interface Props {
  name: string;
  role: string;
  description: string;
  url?: string;
  date: string;
}

const { name, role, description, url, date } = Astro.props;
---

<div class="community-item">
  <div class="header">
    <div class="title-row">
      <h3 class="name-title">
        {name}
        <span class="role-badge">{role}</span>
      </h3>
      <LinkGroup externalUrl={url} />
    </div>
    
    <div class="date-wrapper">
      <DateBadge date={date} />
    </div>
  </div>

  <p class="description">
    {description}
  </p>
</div>

<style>
  @reference "../styles/global.css";

  .community-item {
    @apply mb-1 last:mb-0;
  }

  .header {
    @apply flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-1; 
  }

  .title-row {
    @apply flex items-center gap-2 flex-wrap flex-1;
  }

  .name-title {
    @apply font-bold text-slate-900 group-hover:text-blue-600 transition-colors 
      flex items-center gap-2 text-base;
  }

  .role-badge {
    @apply text-[10px] uppercase tracking-wider font-bold bg-slate-100 
      text-slate-600 px-1.5 py-0.5 rounded border border-slate-200 
      group-hover:bg-blue-50 group-hover:text-blue-600 
      group-hover:border-blue-200 transition-all;
  }


  .description {
    @apply text-sm text-slate-600 mt-0.5 leading-snug;
  }
</style>
