---
interface Props {
  name: string;
  role: string;
  about: string;
  image: string;
  email: string;
  linkedin: string;
  github: string;
  birthDate: string;
  location: string;
}

import IconMail from './icons/IconMail.astro';
import IconLocation from './icons/IconLocation.astro';
import IconCalendar from './icons/IconCalendar.astro';
import IconLinkedin from './icons/IconLinkedin.astro';
import IconGithub from './icons/IconGithub.astro';

const { name, role, about, image, email, linkedin, github, birthDate, location } = Astro.props;
---

<header class="header">
  <div class="main-content">
    <div class="text-block">
      <h1 class="name">{name}</h1>
      <p class="role">{role}</p>
      <p class="about">{about}</p>
    </div>

    <div class="image-container">
      <img src={image} alt={`Photo of ${name}`} loading="eager" />
    </div>
  </div>

  <div class="contact-bar">
    <a href={`mailto:${email}`} class="contact-item">
      <IconMail class="icon" />
      {email}
    </a>

    <span class="dot">•</span>
    
    <div class="contact-item">
      <IconLocation class="icon" />
      {location}
    </div>

    <span class="dot">•</span>

    <div class="contact-item">
      <IconCalendar class="icon" />
      {birthDate}
    </div>

    <span class="dot">•</span>

    <a href={linkedin} target="_blank" rel="noopener noreferrer" class="contact-item">
      <IconLinkedin class="icon" />
      <span>LinkedIn</span>
    </a>

    <span class="dot">•</span>

    <a href={github} target="_blank" rel="noopener noreferrer" class="contact-item">
      <IconGithub class="icon" />
      <span>GitHub</span>
    </a>
  </div>
</header>

<style>
  @reference "../styles/global.css";

  .header {
    @apply pb-1;
  }

  .main-content {
    @apply flex flex-col md:flex-row md:items-start gap-6;
  }

  .text-block {
    @apply order-2 md:order-1 flex-1 min-w-0;
  }

  .name {
    @apply text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight 
      tracking-tight;
  }

  .role {
    @apply text-lg md:text-xl font-semibold text-accent;
  }

  .about {
    @apply text-sm md:text-base text-slate-600 leading-relaxed;
  }

  .image-container {
    @apply order-1 md:order-2 w-28 h-28 md:w-36 md:h-36 shrink-0 mx-auto md:mx-0 
      rounded-full overflow-hidden border border-slate-200 bg-slate-100 mt-4;
  }

  .image-container img {
    @apply w-full h-full object-cover;
  }

  .contact-bar {
    @apply mt-1 flex flex-wrap items-center gap-x-4 gap-y-3 text-sm;
  }

  .contact-item {
    @apply flex items-center gap-1.5 font-medium text-slate-700 
      hover:text-accent transition-colors;
  }

  .icon {
    @apply text-slate-400 size-4.5 group-hover:rotate-12 transition-transform;
  }

  .dot {
    @apply hidden md:inline text-slate-300;
  }

</style>
