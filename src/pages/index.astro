---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import IconDownload from '../components/icons/IconDownload.astro';
import CommunityItem from '../components/ComunityItem.astro';
---

<Layout title="Alexandre Borrazás Mancebo - Portfolio" lang="en">
  <main class="cv-paper">
    <Hero
      name="Alexandre Borrazás Mancebo"
      role="Computer Engineer"
      image="/photo.jpg" 
      email="alexborrazasm@gmail.com"
      linkedin="https://linkedin.com/in/alexborrazasm"
      github="https://github.com/alexborrazasm"
      birthDate="March 2, 1999"
      location='A Coruña, Spain'
      about="Computer Engineering student at UDC with a strong focus on software 
        architecture and system-level development. I build robust solutions by 
        bridging the gap between hardware-constrained environments and high-level 
        software design. From developing real-time APIs for robotics to engineering 
        declarative environments, I apply a maker mindset to solve complex 
        engineering challenges through clean and reproducible code."
    />
    
    <Section title="Education">
      <ExperienceItem 
        title="Degree in Computer Engineering"
        company="Universidade da Coruña (UDC)"
        date="2023 — Present"
        description="Specializing in Computer Engineering. Focused on understanding 
        the full stack of computing, from low-level hardware to high-level software 
        architectures."
        skills={["C/C++", "Java", "MySQL", "Python", "Javascript", "Flutter",
          "Django", "Linux", "HTML5", "CSS3", "ARM"]}
      />
    </Section>

    <Section title="Honors & Awards">
      <ExperienceItem 
        title="First Prize Winner - HackUDC 2026"
        company="Denodo Track"
        date="2026"
        description="Won the first prize in the Denodo challenge, demonstrating 
          problem-solving skills, rapid prototyping and efficient data handling 
          under pressure."
        githubUrl="https://github.com/InnovateXYZ/HackUDC2026"
        externalUrl="https://devpost.com/software/k2-platform-hackudc-2026"
        externalUrlLabel='See on Devpost'
        skills={["React", "Tailwind", "Python", "FastAPI", "Docker",
          "Grafana", "Sqlite", "Data Visualization", "Hackathon"]}
      />
    </Section>
    
    <Section title="Projects">
      <ExperienceItem 
        title="Declarative Infrastructure & Home Lab"
        company="Self-hosted NixOS Ecosystem"
        date="2025 — Present"
        description="Engineered a fully reproducible infrastructure using NixOS 
          (Flakes) and Docker across VPS and on-premise nodes. Implemented 
          declarative system configs, automated backups, and network segmentation 
          with OpenWrt (VLANs). Focused on Infrastructure as Code (IaC) and 
          maintaining services for the BricoLabs community."
        githubUrl="https://github.com/alexborrazasm/nixos-dotfiles" 
        skills={["NixOS", "Docker", "Proxmox", "GNU/Linux", "IaC", 
          "Debian", "Restic", "Wireguard", "OpenWrt", "Git"]}
      />
      <ExperienceItem 
        title="ESP32 Telemetry & Robotics API"
        company="Personal Project / BricoLabs"
        date="2026 — Present"
        description="Architected a hardware-agnostic HTTP/WebSocket API for 
        ESP32 robots. Developed a transport layer abstraction (WiFi/Ethernet) 
        to decouple connectivity from logic. Features real-time data streaming 
        and remote configuration for robotics competitions (OSHWDem)."
        githubUrl="https://github.com/TMP-Robots/TMP-API"
        skills={["ESP32", "C++", "Arduino", "API REST", "WebSockets", "IoT", 
          "Robotics", "API Design", "Git"]}
      />
    </Section>

    <Section title="Communities & Volunteering">
      <CommunityItem 
        name="Wiki.js"
        role="Open Source Contributor"
        url="https://js.wiki"
        description="Contributed to the localization of the platform by 
          translating documentation and core interface elements into Galician."
        date="2026 — Present"
      />
      <CommunityItem 
        name="Universidade da Coruña (UDC)"
        role="Peer Mentor"
        description="Providing academic orientation to first-year Computer 
          Science students. Helping them navigate the curriculum, tooling, and 
          the university's ecosystem."
        date="2025 — Present"
      />
      <CommunityItem 
        name="GPUL"
        role="Member"
        url="https://gpul.org"
        description="Participating in the Free Software Users Group at 
          Universidade da Coruña, promoting FOSS culture through technical 
          workshops and seminars."
        date="2023 — Present"
      />
      <CommunityItem 
        name="OSHWDem Coruña"
        role="Organizer & Judge"
        url="https://oshwdem.org"
        description="Core organizer for one of Spain's largest Open Hardware 
          events (1,800+ attendees). Responsible for competition judging and 
          developing technical infrastructure/services for the tournament 
          stages."
        date="2023 — Present"
      />
      <CommunityItem 
        name="BricoLabs"
        role="Active Member"
        url="https://bricolabs.cc"
        description="Proactive collaboration on OSHW projects. Developed 
          numerous experiments in robotics, electronics and IoT."
        date="2022 — Present"
      />
    </Section>

  </main>

  <div class="download-btn-container">
    <a 
      href="/api/generate-cv" 
      download 
      class="download-btn"
    >
      <IconDownload class="size-5" />
      <span>Download PDF</span>
    </a>
  </div>
</Layout>

<style>
  @reference "../styles/global.css";

  .cv-paper {
    @apply max-w-4xl mx-auto bg-white shadow-2xl md:rounded-md border 
      border-slate-200/50 min-h-[1100px] p-6 my-0 mb-8 md:p-12 md:my-6;
  }

  .download-btn {
    @apply flex items-center gap-2 px-4 py-2 bg-white/80 backdrop-blur-md 
           text-slate-900 font-bold rounded-full border border-white/50 
           shadow-lg hover:bg-accent hover:text-white transition-all 
           hover:scale-105 active:scale-95 print:hidden;
  }

  .download-btn-container {
    @apply max-w-4xl mx-auto flex justify-center
  }

  /* For printing remove shadows and borders */
  @media print {

    .cv-paper {
      @apply shadow-none border-none p-0 m-0;
    }
    main {
      @apply p-0 m-0;
    }
  }

</style>
